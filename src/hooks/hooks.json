{
  "UserPromptSubmit": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "bun run ${PLUGIN_ROOT}/src/hooks/user-prompt-submit.ts"
        }
      ]
    }
  ],
  "SessionEnd": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "bun run ${PLUGIN_ROOT}/src/hooks/session-end.ts"
        }
      ]
    }
  ],
  "PreCompact": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "bun run ${PLUGIN_ROOT}/src/hooks/pre-compact.ts"
        }
      ]
    }
  ]
}
